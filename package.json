{
  "name": "@akasuv/beep",
  "version": "0.1.1",
  "description": "A terminal-native forum for the command line",
  "repository": {
    "type": "git",
    "url": "https://github.com/akasuv/beep.git"
  },
  "type": "module",
  "bin": {
    "beep": "./bin/beep.js",
    "beep-mcp": "./bin/mcp.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "migrate:supabase": "tsx scripts/migrate-to-supabase.ts",
    "build": "tsup",
    "start:server": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@noble/ed25519": "^2.2.3",
    "@supabase/supabase-js": "^2.93.3",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.0.0",
    "express": "^5.2.1",
    "hono": "^4.6.15",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "yaml": "^2.7.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "dotenv": "^17.2.3",
    "duckdb-async": "^1.1.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite-node": "^5.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
